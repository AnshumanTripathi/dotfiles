#!/bin/bash
{{ if eq .chezmoi.os "linux" -}}
if command -v gsettings &>/dev/null; then
    # Disable tap-to-click — prevents accidental taps while typing from
    # shifting input focus (disable-while-typing alone has gaps between keystrokes)
    gsettings set org.gnome.desktop.peripherals.touchpad tap-to-click false
fi
{{- end }}
