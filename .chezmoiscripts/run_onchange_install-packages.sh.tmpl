#!/bin/bash

# packages.yaml hash: {{ .packages | toString | sha256sum }}

{{ $os := .chezmoi.os -}}
{{ $profile := .profile -}}

{{ if eq $os "linux" -}}
# ── Bootstrap yay AUR helper (Arch Linux) ──
if ! command -v yay &> /dev/null; then
    echo "#############################################"
    echo ""
    echo "Installing yay AUR helper"
    echo ""
    sudo pacman -S --needed --noconfirm base-devel git
    TEMP_DIR=$(mktemp -d)
    git clone https://aur.archlinux.org/yay.git "$TEMP_DIR/yay"
    cd "$TEMP_DIR/yay" && makepkg -si --noconfirm
    cd - > /dev/null
    rm -rf "$TEMP_DIR"
fi
{{ end -}}

echo "#############################################"
echo ""
echo "Installing core packages"
echo ""

{{ if eq $os "darwin" -}}
brew bundle --file=/dev/stdin <<EOF
{{ range .packages.brew.core.formulae -}}
brew {{ . | quote }}
{{ end -}}
EOF
{{ else if eq $os "linux" -}}
sudo pacman -S --needed --noconfirm \
{{ range .packages.pacman.core.packages }}  {{ . }} \
{{ end }}

{{ if .packages.pacman.core.aur -}}
yay -S --needed --noconfirm \
{{ range .packages.pacman.core.aur }}  {{ . }} \
{{ end }}
{{ end -}}
{{ end -}}

echo "#############################################"
echo ""
echo "Installing core packages with asdf"
echo ""

# Setup path before processing
PATH="${ASDF_DATA_DIR:-$HOME/.asdf}/shims:$PATH"
{{ range .packages.common.core.asdf -}}
  echo "Adding asdf plugin {{ .name }} {{ .plugin }}"
  asdf plugin add {{ .name }} {{ .plugin }}

  echo ""
  echo "Installing latest version of {{ .name }} with asdf"
  asdf install {{ .name }} latest

  echo ""
  echo "Setting global version for {{.name }} to latest"
  asdf set -u {{ .name }} latest

{{ end -}} {{/* range .packages.common.core.asdf */}}


echo "#############################################"
echo ""
echo "Installing shared packages"
echo ""

{{ if eq $os "darwin" -}}
brew bundle --file=/dev/stdin <<EOF
{{ range .packages.brew.shared.taps -}}
tap {{ . | quote}}
{{ end -}}
{{ range .packages.brew.shared.formulae -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.brew.shared.casks -}}
cask {{ . | quote }}
{{ end -}}
EOF
{{ else if eq $os "linux" -}}
sudo pacman -S --needed --noconfirm \
{{ range .packages.pacman.shared.packages }}  {{ . }} \
{{ end }}

echo ""
echo "Installing shared AUR packages"
echo ""
yay -S --needed --noconfirm \
{{ range .packages.pacman.shared.aur }}  {{ . }} \
{{ end }}
{{ end -}}

echo "#############################################"
echo ""
echo "Installing shared packages using wget"
echo ""

{{ range .packages.common.shared.wgets -}}
TEMP_DIR=$(mktemp -d)
echo "Fetching {{ .name }}"
  {{ if  .tar -}}
    wget {{ .url }} -O - | tar -xz -C "$TEMP_DIR"
  {{ else -}}
    wget {{ .url }} -O $TEMP_DIR/{{ .name }}
    ls "$TEMP_DIR"/{{ .name }}
  {{ end -}}
  mv "$TEMP_DIR"/{{ .name }} "$HOME/bin/"
  chmod +x "$HOME/bin/{{ .name }}"
{{ end -}} {{/* range .packages.common.shared.wgets */}}

echo "#############################################"
echo ""
echo "Installing shared packages using asdf"
echo ""

{{ range .packages.common.shared.asdf -}}
  echo "Adding asdf plugin"
  asdf plugin add {{ .name }} {{ .plugin }}

  echo ""
  echo "Installing latest version of {{ .name }} with asdf"
  asdf install {{ .name }} latest

  echo ""
  echo "Setting global version for {{.name }} to latest"
  asdf set -u {{ .name }} latest

{{ end -}} {{/* range .packages.common.shared.asdf */}}

{{ range .packages.common.shared.npm -}}
  if ! npm list -g {{ . }} &> /dev/null; then
    echo "Installing {{ . }}"
    npm install -g {{ . }}
  else
    echo "{{ . }} already installed"
  fi
{{ end -}}


{{ if .packages.common.profiles -}}

echo "#############################################"
echo ""
echo "Installing ({{ .profile }}) profile specific packages"
echo ""

{{ if eq $os "darwin" -}}
brew bundle --file=/dev/stdin <<EOF
{{ range (index .packages.brew.profiles $profile).taps -}}
tap {{ . | quote }}
{{ end -}}
{{ range (index .packages.brew.profiles $profile).formulae -}}
brew {{ . | quote }}
{{ end -}}
{{ range (index .packages.brew.profiles $profile).casks -}}
cask {{ . | quote }}
{{ end -}}
EOF
{{ else if eq $os "linux" -}}
sudo pacman -S --needed --noconfirm \
{{ range (index .packages.pacman.profiles $profile).packages }}  {{ . }} \
{{ end }}

{{ if (index .packages.pacman.profiles $profile).aur -}}
yay -S --needed --noconfirm \
{{ range (index .packages.pacman.profiles $profile).aur }}  {{ . }} \
{{ end }}
{{ end -}}
{{ end -}}

echo "#############################################"
echo ""
echo "Installing ({{ .profile }}) profile specific packages using npm"
echo ""
{{ range (index .packages.common.profiles $profile).npm -}}
  if ! npm list -g {{ . }} &> /dev/null; then
    echo "Installing {{ . }} for {{ $profile }} profile"
    npm install -g {{ . }}
  else
    echo "{{ . }} already installed"
  fi
{{ end -}}{{/* range (index .packages.common.profiles $profile).npm */}}

echo "#############################################"
echo ""
echo "Installing ({{ .profile }}) profile specific packages using wget"
echo ""

{{ if eq $os "darwin" -}}
{{ range (index .packages.common.profiles $profile).wgets.darwin -}}
TEMP_DIR=$(mktemp -d)
echo "Fetching {{ .name }}"
  {{ if  .tar -}}
    wget {{ .url }} -O - | tar -xz -C "$TEMP_DIR"
  {{ else -}}
    wget {{ .url }} -O $TEMP_DIR/{{ .name }}
    ls "$TEMP_DIR"/{{ .name }}
  {{ end -}}
  mv "$TEMP_DIR"/{{ .name }} "$HOME/bin/"
  chmod +x "$HOME/bin/{{ .name }}"
{{ end -}} {{/* range wgets.darwin */}}
{{ else if eq $os "linux" -}}
{{ range (index .packages.common.profiles $profile).wgets.linux -}}
TEMP_DIR=$(mktemp -d)
echo "Fetching {{ .name }}"
  {{ if  .tar -}}
    wget {{ .url }} -O - | tar -xz -C "$TEMP_DIR"
  {{ else -}}
    wget {{ .url }} -O $TEMP_DIR/{{ .name }}
    ls "$TEMP_DIR"/{{ .name }}
  {{ end -}}
  mv "$TEMP_DIR"/{{ .name }} "$HOME/bin/"
  chmod +x "$HOME/bin/{{ .name }}"
{{ end -}} {{/* range wgets.linux */}}
{{ end -}}

echo "#############################################"
echo ""
echo "Installing ({{ .profile }}) profile specific packages using asdf"
echo ""
{{ range (index .packages.common.profiles $profile).asdf -}}
  echo "Adding asdf plugin"
  asdf plugin add {{ .name }} {{ .plugin }}
  echo "Installing latest version of {{ .name }} with asdf"
  asdf install {{ .name }} latest
  echo "Setting global version for {{.name }} to latest"
  asdf set -u {{ .name }} latest
{{ end -}} {{/* range (index .packages.common.profiles $profile).asdf */}}
{{ end -}}{{/* if .packages.common.profiles */}}

{{ if eq .aiAgent "claude-code" -}}
echo "#############################################"
echo ""
echo "Installing Claude Code"
echo ""
{{ if eq $os "darwin" -}}
brew install --cask claude-code
{{ else if eq $os "linux" -}}
if ! command -v claude &> /dev/null; then
  npm install -g @anthropic-ai/claude-code
  # Native install
  calude install
  npm uninstall -g @anthropic-ai/claude-code
else
  echo "@anthropic-ai/claude-code already installed"
fi
{{ end -}}
{{ end -}}{{/* if eq .aiAgent "claude-code" */}}
