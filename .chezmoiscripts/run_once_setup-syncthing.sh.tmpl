#!/bin/bash
{{ if and (eq .chezmoi.os "linux") (eq .profile "personal") -}}
set -euo pipefail

echo "#############################################"
echo "Setting up syncthing systemd user service"
echo "#############################################"

if ! command -v syncthing &>/dev/null; then
  echo "syncthing not found, skipping service setup"
  exit 0
fi

systemctl --user enable --now syncthing.service

echo "syncthing service enabled and started"
echo "Web UI available at http://localhost:8384"
{{ end -}}
