{{- $email := promptStringOnce . "email" "Email address" -}}
{{- $useGhostty := promptBoolOnce . "useGhostty" "Use Ghostty" -}}
{{- $terminalFont := 16 }}
{{- if $useGhostty }}
{{-     $terminalFont = promptIntOnce . "terminalFont" "Enter terminal font" 16 }}
{{- end -}}
{{- $choices := list "personal" "work" -}}
{{- $profile := promptChoiceOnce . "profile" "Profile to use" $choices -}}
{{- $useStarshipPrompt := promptBoolOnce . "useStarshipPrompt" "Use starship prompt" -}}
{{- $haveSigningKey := promptBoolOnce . "haveSigningKey" "Do you have a GPG signing key" -}}
{{- $signingKey := "" }}
{{- if $haveSigningKey }}
{{-     $signingKey = promptStringOnce . "signingKey" "Enter signing key id" }}
{{- end }}
{{- $useAIAgent := promptBoolOnce . "useAIAgent" "Use an AI coding agent" -}}
{{- $aiAgent := "" }}
{{- if $useAIAgent }}
{{-     $aiAgentChoices := list "windsurf" "claude-code" -}}
{{-     $aiAgent = promptChoiceOnce . "aiAgent" "AI agent" $aiAgentChoices }}
{{- end }}
{{- $installContainerTools := promptBoolOnce . "installContainerTools" "Install container tools (kubernetes, helm, dive, etc)" -}}
{{- $installInfraTools := promptBoolOnce . "installInfraTools" "Install infra tools (ansible, terraform, direnv)" -}}
{{- $installSecurityTools := promptBoolOnce . "installSecurityTools" "Install security tools (nmap, wireshark, snyk)" -}}
{{- $installPythonTools := promptBoolOnce . "installPythonTools" "Install Python tools (pyenv, pyenv-virtualenv)" -}}
{{- $installBackupTools := promptBoolOnce . "installBackupTools" "Install backup tools (restic, btrbk)" -}}
encryption = "gpg"
[gpg]
    args = ["--quiet"]
    recipient = "32EAC9CCB3CA960E03893BA4647FB5AF905AA26D"
[data]
    email = {{ $email | quote  }}
    profile = {{ $profile | quote  }}
    useGhostty = {{ $useGhostty }}
    terminalFont = {{ $terminalFont }}
    useStarshipPrompt = {{ $useStarshipPrompt | quote }}
    haveSigningKey = {{ $haveSigningKey }}
    signingKey = {{ $signingKey | quote }}
    useAIAgent = {{ $useAIAgent }}
    aiAgent = {{ $aiAgent | quote }}
    installContainerTools = {{ $installContainerTools }}
    installInfraTools = {{ $installInfraTools }}
    installSecurityTools = {{ $installSecurityTools }}
    installPythonTools = {{ $installPythonTools }}
    installBackupTools = {{ $installBackupTools }}
[edit]
    command = "code"
    args = ["--wait"]
